# Copy this file to ".env" and fill the values.

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Supabase (database) ─────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ─── Admin panel login ───────────────────────────────────────
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_TOKEN_SECRET=any-long-random-secret-string

# ─── Email (Gmail/Workspace SMTP via Nodemailer) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=executive@bellamarinvest.com
SMTP_PASS=your-google-app-password
LEAD_NOTIFY_TO=executive@bellamarinvest.com
